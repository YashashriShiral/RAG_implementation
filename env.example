# ── OpenRouter (replaces Ollama for Railway deployment) ───────────────────────
# Get free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ── Ollama (local dev only — ignored if OPENROUTER_API_KEY is set) ────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Cohere reranking ──────────────────────────────────────────────────────────
COHERE_API_KEY=your_cohere_api_key_here
COHERE_RERANK_MODEL=rerank-english-v3.0

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_live_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
USER_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX
USER_NAME=Yashashri

# ── FastAPI ───────────────────────────────────────────────────────────────────
# On Railway: set API_BASE_URL to your Railway FastAPI service URL
API_BASE_URL=http://localhost:8000
FASTAPI_BASE_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=endometriosis_papers

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-base-en-v1.5

# ── RAG tuning ────────────────────────────────────────────────────────────────
CHUNK_SIZE=900
CHUNK_OVERLAP=200
RETRIEVER_K=40
RERANKER_TOP_N=4
BM25_WEIGHT=0.35
VECTOR_WEIGHT=0.65

# ── Admin monitoring dashboard ───────────────────────────────────────────────
ADMIN_PASSWORD=your-secret-password-here

# ── Optional web search ───────────────────────────────────────────────────────
TAVILY_API_KEY=
